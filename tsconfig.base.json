{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@devagent-runner/core": [
        "packages/core/src/index.ts"
      ],
      "@devagent-runner/local-runner": [
        "packages/local-runner/src/index.ts"
      ],
      "@devagent-runner/adapters": [
        "packages/adapters/src/index.ts"
      ],
      "@devagent-runner/cli": [
        "packages/cli/src/index.ts"
      ]
    },
    "types": [
      "node"
    ]
  }
}
